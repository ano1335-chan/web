            if( (navigator.appName==sNetscapeNavigator) && (vVerCompatible<5) ){
               // Netscape
               
               location.reload(); // false // キャシュ から リロード．
               // location.reload(true); // サーバ から リロード．
               
            }
            
            else{ 
               // Explorer
               
            }
            
         }
         
         // -->
      </script>

