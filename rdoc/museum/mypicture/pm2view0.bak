   <body bgcolor="#8f9fff" text="#000000" link="#2f2fff" vlink="#d700d7" alink="#00ffff" onLoad="BodyLoad()">

      <script language="JavaScript">
         <!-- 
         // --　▼▼▼　Load Check："JS" File Version 0.L　▼▼▼　-- //
         if( navigator.appName=="Microsoft Internet Explorer" ){
            LoadCheck_JavaScript_InternetExplorer( );
         }
         function LoadCheck_JavaScript_InternetExplorer( ){
            sProtocol = location.protocol;
            sLocatPath = location.pathname; vReloadMax = 12;
            if( -1==sProtocol.indexOf("http:") ){ vReloadMax = 32; }
            vOperand = 1; sParameter = location.search;
            sSelfFileName = sLocatPath.substring(Math.max(sLocatPath.lastIndexOf("/"),sLocatPath.lastIndexOf(unescape("%5c")))+1,sLocatPath.length);
            vParamReload = sParameter.lastIndexOf("@Reload=");
            // unescape("%5c") の変わりに"\\"を記述した場合，Perl の ソースとして移植すると"\"に変換されてしまうが、それは仕様のようだ．
            if(0<=vParamReload){
               vOperand = Number( sParameter.substring(vParamReload+8) )+1;
               sParameter = sParameter.substring(0,vParamReload);
            }
            if( sParameter=="" ) sParameter = "?";
            if( 2<=sParameter.length && sParameter.charAt(sParameter.length-1)!=";" ){
               sParameter += ";";
            }
            sParameter += "@Reload="+vOperand; 
            lInteractive = (0<document.body.clientWidth)&&(0<document.body.clientHeight); // true; // false; //
            for( i = 0; i < document.all.tags("script").length; i++ ){
               sScriptPathName = document.all.tags("script")(i).src;
               sScriptLeafName = sScriptPathName.substring(sScriptPathName.lastIndexOf("/")+1,sScriptPathName.length); 
               if(sScriptLeafName!=""){
                  // lInteractive = lInteractive && document.all.tags("script")(i).document.readyState=="interactive";
                  // ドキュメントのダウンロード状態を "uninitialized", "loading", "interactive", "complete" のいずれかの文字列で返す。
                  sFirstNeme = sScriptLeafName.substring(0,sScriptLeafName.lastIndexOf("."));
                  if( 0<=sScriptLeafName.lastIndexOf("LoadCheck_JavaScript") ){
                     try{ lInteractive = lInteractive && eval("lExist_JavaScript_"+sFirstNeme+"( );"); }
                     catch(sExp){ lInteractive = false; } // true; //
                  }
               }
            }
            try{ InitViewBoundary( ); lInteractive = lInteractive && 0<vFrameWidth && 0<vFrameHeight; }
            catch(sExp){ lInteractive = false; } // true; //
            // alert("sSelfFileName+sParameter+location.hash="+sSelfFileName+sParameter+location.hash); lInteractive = false; // true; //
            if( ! lInteractive ){
               if( vOperand<=vReloadMax ){
                  location.reload(sSelfFileName+sParameter+location.hash); 
                  // location.reload( ); // false // キャシュ から リロード．
                  // location.reload(true); // サーバ から リロード．
               }
               else if( 0==sProtocol.indexOf("http:") ){
                  alert("★ Time-Out：\"JS\"ファイルが存在しない，または設置場所が間違ってるか，\"JS\"ファイルがサーバー側の問題によってロード遅延となってるか，無料サイトの広告用 JavaScript で致命的なエラーが発生し\"JS\"ファイルが正常に実行できない可能性があります．");
               }
            }
         }
         // --　▲▲▲　Load Check："JS" File Version 0.L　▲▲▲　-- //
         // -->
      </script>

