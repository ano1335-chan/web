<!-- align="left" "center"  -->

  <script language="JavaScript">
    <!--
    
    if( 0<(*&$FUploadAppendixQuantityMax&+0) ){
      
      sInputWidth = '55';
      
      if( navigator.appName==sInternetExplorer ){
        Explorer_Make_FUpload_Input( 'Appendix', 'width: '+sInputWidth+'ex; ', *&$FUploadAppendixQuantityMax&+0 );
      // 「form などの名前の Prefix、ファイル名 入力用 Input テキスト･フィールドの CSS、ファイル名 入力用 Input テキスト･フィールドの最大個数」を指定。
      }
      else{
        Gecko_Make_FUpload_Input( 'Appendix', '', *&$FUploadAppendixQuantityMax&+0 );
      }
      
    }
    
    function Gecko_Make_FUpload_Input( sPrefix, sInputCSS, vInputQuantity ){
      var sOnChange, sOnChangeParam0, sOnChangeParam1, sDisplay, sOnClick, sOnClickParam0, vCount, sMessage, vAppendixSizeMax;
      if( 0<vInputQuantity ){
        document.write('<table cellpadding="0" cellspacing="0" border=0 class="border_none" style="width: 0%; left:0px"><tr><td nowrap>');
        document.write('<input id="'+sPrefix+'/Setting/InputQuantity" type="hidden" value="'+vInputQuantity+'" >');
        document.write('<input id="'+sPrefix+'/Setting/InputCSS" type="hidden" value="'+sInputCSS+'" >');
        sDisplay = '';
        for(vCount = 0; vCount<vInputQuantity; vCount++){
          document.write('<div id="'+sPrefix+'/FUpload/DHTML/ID.'+vCount+'" style="'+sDisplay+'" >');
          // sOnClickParam0 = "'"+sPrefix+"/FUpload/DHTML/ID."+vCount+"'";
          sOnClickParam0 = " this, '"+sPrefix+"/FUpload/Input/ID."+vCount+"' ";
          document.write('<input type="checkbox" checked onClick="Switch_InputFile('+sOnClickParam0+');"> ');
          
          sOnChangeParam0 = "'"+sPrefix+"'";
          // sOnChangeParam2 = "'"+sInputCSS+"'";
          sOnChange = 'Add_InputFile('+sOnChangeParam0+','+(vCount+1)+');';
          document.write('<input id="'+sPrefix+'/FUpload/Input/ID.'+vCount+'" name="'+sPrefix+'/FUpload/Input" type="file" multiple style="'+sInputCSS+'" '+' onChange="'+sOnChange+'" >');
          document.write('<br>');
          document.write('</div>');
          sDisplay = ' display: none; ';
        }
        document.write('<div id="'+sPrefix+'/FUpload/DHTML/ID.'+vInputQuantity+'" align="center" style="color: #ff0000; font-weight: bold; background-color: #00ff00; display: none; " >End Of Input.<br></div>');
        document.write('</td></tr></table>');
      }
      
      sMessage = "<&=※ Input File の 行頭のチェックボックスを Off にすることにより、その行のファイルのアップロードをキャンセルすることができます．<br>=&>";
      document.write(sMessage);
    }
    
    function Add_InputFile( sPrefix, vCount ){
      var sOnChange, sOnChangeParam0, sOnChangeParam1, sDisplay, sOnClick, sOnClickParam0, sMatch;
      // var oFUpload_Form = document.forms[ sPrefix+'/FUpload/Form' ];
      var oInputQuantity = document.getElementById( sPrefix+'/Setting/InputQuantity' );
      var oInputCSS = document.getElementById( sPrefix+'/Setting/InputCSS' );
      var vInputQuantity = parseFloat( oInputQuantity.value );
      var sInputCSS = oInputCSS.value;
      var oFUpload_DHTML = document.getElementById( sPrefix+'/FUpload/DHTML/ID.'+vCount );
      // sMatch =  oFUpload_DHTML.innerHTML.match( /^display: none;$/i );
      if( oFUpload_DHTML.style.display=='none' ){
        if( vCount<vInputQuantity ){
          oFUpload_DHTML.style.display = 'block';
        }
        else{
          if( 1<vInputQuantity ){
            oFUpload_DHTML.style.display = 'block';
          }
        }
      }
      
    }
    
    function Explorer_Make_FUpload_Input( sPrefix, sInputCSS, vInputQuantity ){
      var sOnChange, sOnChangeParam0, sOnChangeParam1, sDisplay, sOnClick, sOnClickParam0, vCount, sMessage, vAppendixSizeMax;
      if( 0<vInputQuantity ){
        document.write('<table cellpadding="0" cellspacing="0" border=0 class="border_none" style="width: 0%; left:0px"><tr><td nowrap>');
        document.write('<input id="'+sPrefix+'/Setting/InputQuantity" type="hidden" value="'+vInputQuantity+'" >');
        document.write('<input id="'+sPrefix+'/Setting/InputCSS" type="hidden" value="'+sInputCSS+'" >');
        sDisplay = '';
        for(vCount = 0; vCount<vInputQuantity; vCount++){
          if( vCount==0 ){
          document.write('<div id="'+sPrefix+'/FUpload/DHTML/ID.'+vCount+'" style="'+sDisplay+'" >');
            sOnClickParam0 = "'"+sPrefix+"/FUpload/DHTML/ID."+vCount+"'";
            document.write('<&=(Contribution:FUpload:Erase):<input type="button" value="消去" onClick="Reset_InputFile('+sOnClickParam0+');">=&> ');
            
            sOnChangeParam0 = "'"+sPrefix+"'";
            // sOnChangeParam2 = "'"+sInputCSS+"'";
            sOnChange = 'Explorer_Add_InputFile('+sOnChangeParam0+','+(vCount+1)+');';
            document.write('<input id="'+sPrefix+'/FUpload/Input/ID.'+vCount+'" name="'+sPrefix+'/FUpload/Input" type="file" multiple style="'+sInputCSS+'" '+sDisplay+' onChange="'+sOnChange+'" >');
            document.write('<br>');
            document.write('</div>');
          }
          else{
            document.write('<div id="'+sPrefix+'/FUpload/DHTML/ID.'+vCount+'" style="'+sDisplay+'" >');
            // document.write('<input type=hidden name=Dummy>');
            document.write('</div>');
          }
          sDisplay = ' display: none; ';
        }
        document.write('<div id="'+sPrefix+'/FUpload/DHTML/ID.'+vInputQuantity+'" align="center" style="color: #ff0000; font-weight: bold; background-color: #00ff00; '+sDisplay+'" >');
        // document.write('<input type=hidden name=Dummy>');
        document.write('</div>');
        document.write('</td></tr></table>');
      }
      // document.write("FUploadAppendixSizeMax=*&$FUploadAppendixSizeMax&");
      // vAppendixSizeMax = ( *&$FUploadAppendixSizeMax&+0 )/1024;
      // sMessage = "<&=※ファイル･サイズは <STRIKE>&$FUploadAppendixSizeMax</STRIKE> までアップロード可能です．<br>=&>";
      // sMessage = sMessage.replace(/<STRIKE>\&\$FUploadAppendixSizeMax<\/STRIKE>/g, (""+vAppendixSizeMax+"kByte") );
      // document.write(sMessage);
    }
    
    function Explorer_Add_InputFile( sPrefix, vCount ){
      var sOnChange, sOnChangeParam0, sOnChangeParam1, sDisplay, sOnClick, sOnClickParam0, sMatch;
      // var oFUpload_Form = document.forms[ sPrefix+'/FUpload/Form' ];
      var oInputQuantity = document.getElementById( sPrefix+'/Setting/InputQuantity' );
      var oInputCSS = document.getElementById( sPrefix+'/Setting/InputCSS' );
      var vInputQuantity = parseFloat( oInputQuantity.value );
      var sInputCSS = oInputCSS.value;
      var oFUpload_DHTML = document.getElementById( sPrefix+'/FUpload/DHTML/ID.'+vCount );
      // sMatch =  oFUpload_DHTML.innerHTML.match( /^<input type=hidden name=Dummy>$/i );
      if( oFUpload_DHTML.style.display=='none' ){
        if( vCount<vInputQuantity ){
          sDisplay = '';
          sOnChangeParam0 = "'"+sPrefix+"'";
          sOnChangeParam2 = "'"+sInputCSS+"'";
          sOnChange = 'Explorer_Add_InputFile('+sOnChangeParam0+','+(vCount+1)+','+sOnChangeParam2+','+vInputQuantity+');';
          sOnClickParam0 = "'"+sPrefix+"/FUpload/DHTML/ID."+vCount+"'";
          oFUpload_DHTML.innerHTML = 
           '<&=(Contribution:FUpload:Erase):<input type="button" value="消去" onClick="Reset_InputFile('+sOnClickParam0+');">=&> '+
           '<input id="'+sPrefix+'/FUpload/Input/ID.'+vCount+'" name="'+sPrefix+'/FUpload/Input" type="file" multiple style="'+sInputCSS+'" '+sDisplay+' onChange="'+sOnChange+'" >'+
          '<br>';
          oFUpload_DHTML.style.display = 'block';
        }
        else{
          if( 1<vInputQuantity ){
            oFUpload_DHTML.innerHTML = 'End Of Input.<br>';
            oFUpload_DHTML.style.display = 'block';
          }
        }
      }
    }
    
    function Switch_InputFile( oCheckbox, sIFile ){
      var oIFile = document.getElementById(sIFile);
      // oIFile.disabled = false; // true; //
      oIFile.disabled = ! oCheckbox.checked;
    }
    function Reset_InputFile( sIFile ){
      var oIFile = document.getElementById(sIFile);
      oIFile.innerHTML = oIFile.innerHTML;
    }
    // -->
  </script>

