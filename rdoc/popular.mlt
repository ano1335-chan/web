      <script language='JavaScript'>
         <!--
         function SubmitFixArticleIndexAction(sTarget){
            if( (typeof sTarget)=='undefined' ){
               sTarget = '';
            }
            document.FormSubmitFixArticleIndex.target = sTarget;
            document.FormSubmitFixArticleIndex.submit( );
         }
         function SubmitNonArticleIndexAction(sTarget, sSeparator, sBTS_Operator, sBlockTimeStamp, sBID_Operator, sBlockIdentity, sTSN_Operator, sSerialNumber, sBAD_Operator, sBlockAddress){
            var sSearchMode,sSearchCondition;
            if( (typeof sTarget)=='undefined' ){
               sTarget = '';
            }
            sSearchMode = document.FormSubmitNonArticleIndex.SearchMode.value;
            sSearchCondition = document.FormSubmitNonArticleIndex.SearchCondition.value;
            if( sTarget=="_blank" ){
               document.FormSubmitNonArticleIndex.SearchMode.value = '';
               document.FormSubmitNonArticleIndex.SearchCondition.value = '';
            }
            document.FormSubmitNonArticleIndex.target = sTarget;
            document.FormSubmitNonArticleIndex.Execution.value = 'Express';
            document.FormSubmitNonArticleIndex.BlockTimeStamp.value = '';
            document.FormSubmitNonArticleIndex.BlockIdentity.value = '';
            document.FormSubmitNonArticleIndex.ThreadSerialNumber.value = '';
            document.FormSubmitNonArticleIndex.BlockAddress.value = '';
            if( (typeof sBlockTimeStamp)=='undefined' ){
               sBlockTimeStamp = '';
            }
            if( (typeof sBlockIdentity)=='undefined' ){
               sBlockIdentity = '';
            }
            if( (typeof sSerialNumber)=='undefined' ){
               sSerialNumber = '';
            }
            if( (typeof sBlockAddress)=='undefined' ){
               sBlockAddress = '';
            }
            if( sBlockIdentity!='' ){
               document.FormSubmitNonArticleIndex.Execution.value = 'JumpIdentity';
               document.FormSubmitNonArticleIndex.BlockIdentity.value = sBlockIdentity;
               document.FormSubmitNonArticleIndex.action = document.FormSubmitNonArticleIndex.action+sBID_Operator+sBlockIdentity+sSeparator;
            }
            if( (sBlockIdentity!='') && (sSerialNumber!='') ){
               document.FormSubmitNonArticleIndex.Execution.value = 'JumpThread';
               document.FormSubmitNonArticleIndex.ThreadSerialNumber.value = sSerialNumber;
               document.FormSubmitNonArticleIndex.action = document.FormSubmitNonArticleIndex.action+sTSN_Operator+sSerialNumber+sSeparator;
            }
            if( sBlockAddress!='' ){
               document.FormSubmitNonArticleIndex.BlockAddress.value = sBlockAddress;
               document.FormSubmitNonArticleIndex.action = document.FormSubmitNonArticleIndex.action+sBAD_Operator+sBlockAddress+sSeparator;
            }
            if( sBlockTimeStamp!='' ){
               document.FormSubmitNonArticleIndex.BlockTimeStamp.value = escape(sBlockTimeStamp);
               document.FormSubmitNonArticleIndex.action = document.FormSubmitNonArticleIndex.action+sBTS_Operator+sBlockTimeStamp+sSeparator;
            }
            if( sTarget=="_blank" ){
               document.FormSubmitNonArticleIndex.submit( );
               document.FormSubmitNonArticleIndex.SearchMode.value = sSearchMode;
               document.FormSubmitNonArticleIndex.SearchCondition.value = sSearchCondition;
            }
            else{ // if( sTarget!="_blank" )
               document.FormSubmitNonArticleIndex.submit( );
            }
         }
         // -->
      </script>
      

