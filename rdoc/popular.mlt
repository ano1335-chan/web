      <table align="center" cellpadding="10" border=1 class="border_default-outer ">
         <tr>
            <td class="border_default-inner ">

               <table cellpadding="0" cellspacing="0" border=0 class="border_none" style="left:0px">
               <form name="FormContribution" method="POST" action="*&$ProgramName&?*&$Option&" enctype="multipart/form-data" style="display: inline; ">
               <tr><td>

<&=(Contribution):Title：=&>
                  <input type="text" size="40" name="CommentTitle">

                  <input type="checkbox" name="UserCheckCommentTitle" *&$UserCheckCommentTitle&>
<&=(Contribution):：未入力をチェック．<br>=&>

