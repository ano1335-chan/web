            // sJumpLocation = sLHash;
            
         }
         
         if(sJumpLocation != ""){
            
            location.hash = sJumpLocation;
            
         }
         
         function Finalize_Display( ){
            
            if(sJumpLocation != ""){
               
               if( ! ( (navigator.appName == sNetscapeNavigator) && (vVerCompatible < 5) ) ){
                  // InternetExplorer
                  
                  location.hash = sJumpLocation;
                  
