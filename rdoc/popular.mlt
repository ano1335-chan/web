      <script language="JavaScript">
         <!--
         
         //Initialize.
         
         dRadioButton[vRadioButton_SearchExpress] = "*&$SearchExpress&";
         
         function Search_OnLoad(){
            // document.FormSearchCondition.AffirmOr.value =  unescape("*&$AffirmOrEsc&");
            // document.FormSearchCondition.AffirmAnd.value =  unescape("*&$AffirmAndEsc&");
            // document.FormSearchCondition.DenialOr.value =  unescape("*&$DenialOrEsc&");
            // document.FormSearchCondition.DenialAnd.value =  unescape("*&$DenialAndEsc&");
         }
         
         function SubmitSearch(oForm){
            if( 
             (oForm.AffirmOr.value=="") &&
             (oForm.AffirmAnd.value=="") &&
             (oForm.DenialOr.value=="") &&
             (oForm.DenialAnd.value=="")
            ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★検索･条件：｛肯定｛OR／AND｝；否定｛OR／AND｝｝の いずれにも条件が入力されていません．"=&>+"\n";
            }
            if( 
             (oForm.AffirmOr.value!="") &&
             (oForm.AffirmAnd.value!="")
            ){
               if(dRadioButton[vRadioButton_AffirmCondition]==""){
                  // sProgramErrorMessage = sProgramErrorMessage+<&="★肯定の OR と AND の条件が入力されていません．"=&>+"\n";
               }
            }
            if( 
             (oForm.DenialOr.value!="") &&
             (oForm.DenialAnd.value!="")
            ){
               if(dRadioButton[vRadioButton_DenialCondition]==""){
                  // sProgramErrorMessage = sProgramErrorMessage+<&="★否定の OR と AND の条件が入力されていません．"=&>+"\n";
               }
            }
            if( 
             (
              (oForm.AffirmOr.value!="") ||
              (oForm.AffirmAnd.value!="")
             ) && (
              (oForm.DenialOr.value!="") ||
              (oForm.DenialAnd.value!="")
             )
            ){
               if(dRadioButton[vRadioButton_AffirmCondition]==""){
                  // sProgramErrorMessage = sProgramErrorMessage+<&="★肯定と否定の条件が入力されていません．"=&>+"\n";
               }
            }
            if( dRadioButton[vRadioButton_SearchExpress] == "" ){
               sProgramErrorMessage = sProgramErrorMessage+<&=(Search):"★表示･単位が入力されていません．"=&>+"\n";
            }
            if( 0 < sProgramErrorMessage.length ){
               alert(sProgramErrorMessage);
               sProgramErrorMessage = "";
            }
            else{
               oForm.submit( );
            }
         }
         
         // -->
      </script>

