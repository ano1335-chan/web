<!--
◆ここで<head>…</head>タグ内の記述が可能。

<title>…</title>タグで Title は記述しないで下さい。
<meta http-equiv='Content-Type' content='text/html; charset=…'>タグで Charset は記述しないで下さい。
<meta name="robots" content="…">は"smt.cgi"内の"$search_engine__define__str"で設定して下さい。
<meta name="keywords" content="…">用の"検索用･キーワード"は各掲示板ごとに"personal.cfg"内の"HTMLContentKeywords"で設定して下さい。
<meta name="description" content="…">用の"検索用･紹介文"は各掲示板ごとに"personal.cfg"内の"HTMLContentDescription"で設定して下さい。
-->

<!--
サイトのトップ･ページ
<link rel="index" href="…">

ヘルプ･ページ
<link rel="help" href="…">

サイト･マップが掲載されているページ
<link rel="contents" href="…">

検索エンジンに登録して欲しい URL
<link rel="canonical" href="…">

bookmark ブックマーク
<link rel="bookmark" href="…">

何ページかに わたって記事がある場合の最初のページ
<link rel="start" href="…">

次のページ
<link rel="next" href="…">

前のページ
<link rel="prev" href="…">

上位のページ
<link rel="parent" href="…">

相対パスの場合は"smt.cgi"からの相対パスとなる。
下記の変数も使用可（";"（セミコロン）は省略可）．
*&$SiteResourceLocation&;　サイト 資源･URLアドレス（論理的なサイトのトップ）．
*&$CardinalResourceLocation&;　基点 資源･URLアドレス．
*&$LocalResourceLocation&;　ローカル 資源･URLアドレス．
*&$EmployResourceLocation&;　使役 資源･URLアドレス．
*&$InformStageResourceLocation&;　インフォーム･ステージ 資源･URLアドレス．
*&$ReferenceResourceLocation&;　リファレンス 資源･URLアドレス．
*&$ProgramName&;　プログラム･ネーム
*&$HelpFileName&;　ヘルプ･ファイル･ネーム
-->

<link rel="index" href="*&$SiteResourceLocation&;index.htm">
<link rel="index" href="*&$SiteResourceLocation&;index.html">
<link rel="canonical" href="*&$SiteResourceLocation&;index.htm">
<link rel="canonical" href="*&$SiteResourceLocation&;index.html">
<link rel="canonical" href="*&$ProgramName&;">
<link rel="help" href="*&$InformStageResourceLocation&;*&$HelpFileName&;">

<style type='text/css'>
<!--

/* ▼外部スタイル･シート ファイル参照

@import url( ～.css );

下記の変数も使用可（";"（セミコロン）は省略可）．
*&$SiteResourceLocation&;　サイト 資源･URLアドレス（論理的なサイトのトップ）．
*&$CardinalResourceLocation&;　基点 資源･URLアドレス．
*&$LocalResourceLocation&;　ローカル 資源･URLアドレス．
*&$EmployResourceLocation&;　使役 資源･URLアドレス．
*&$InformStageResourceLocation&;　インフォーム･ステージ 資源･URLアドレス．
*&$ReferenceResourceLocation&;　リファレンス 資源･URLアドレス．

例．@import url( *&$SiteResourceLocation&;X-FILE.css );
*/

/* ▼HTML の スタイル･シート */

/* テキスト･カラー． */
body { color: #000000; }

/* .html-body_blue_decoration { background: #8f9fff; } */

.html-body_yellow-green_decoration { background: #d3e7cb; }

.html-body_light-blue_decoration { background: #bfc7ef; }

.html-body_light-violet_decoration { background: #dbd7f3; }

.html-body_violet_decoration { background: #cbb7e7; }

.html-body_light-brown_decoration { background: #cbc7b3; }

/* a:link：未訪問のリンク･テキスト･カラー． */
a:link { color: #004bff; }

/* a:visited：訪問済みのリンク･テキスト･カラー． */
a:visited { color: #a300a3; }

/* a:active：選択中のリンク･テキスト･カラー． */
a:active { color: #00ffff; }

/* a:hover：マウス･カーソル が リンク 上に来た場合の リンク･テキスト･カラー． */
a:hover { color: #ff2f5f; }

/* 引用文の装飾． */
.quotation_decoration{ color: #4f33ff; }

/* アイ･キャッチの装飾． */
.eye-catching_decoration { color: #ff2f5f; font-weight: bold; }
/* font-weight: lighter, normal, bold, bolder; */

/* 掲示板用 ハンドルネームの装飾． */
.BOARD_handle-name_decoration { color: #7347ff; font-weight: bolder; }
/* font-weight: lighter, normal, bold, bolder; */

/* 掲示板用 コメント･タイトルの装飾． */
.BOARD_comment-title_decoration { color: #0083ff; font-weight: bold; }
/* font-weight: lighter, normal, bold, bolder; */

/* 掲示板の検索･モード「真のスレッド」の装飾． */
.BOARD_search_true-thread_decoration { background: #d3e7cb; }

/* 掲示板の検索･モード「偽のスレッド」の装飾． */
.BOARD_search_false-thread_decoration {  }

/* 掲示板の新規投稿記事 日付の装飾． */
.BOARD_new-article_time-stamp_decoration { color: #ff0000; }

/* 掲示板用 管理者 アイ･キャッチの装飾． */
.BOARD_administra_eye-catching_decoration { color: #9f1fe7; }

/* 掲示板用 記事･Index の装飾． */
.BOARD_article-index_decoration {  }

/* 掲示板用 記事･Index ハンドルネーム の装飾． */
.BOARD_article-index_handle-name_decoration {  }

/* 掲示板用 記事･Index コメント･タイトル の装飾． */
.BOARD_article-index_comment-title_decoration {  }


.border_default-outer {
   border-color: #ffffff #7f7f7f #7f7f7f #ffffff;
   border-style: solid solid solid solid;
   border-width: 1px 1px 1px 1px;
}
.border_default-inner {
   border-color: #7f7f7f #ffffff #ffffff #7f7f7f;
   border-style: solid solid solid solid;
   border-width: 1px 1px 1px 1px;
}

.pop-up_container {
   display: inline; /* inline で表示 */
}
.pop-up_display_area {
}
a:hover.pop-up_link { /* マウスが乗った場合　リンク */
   /* position: relative; */
   text-decoration: none;
}
a:hover .pop-up_balloon { /* マウスが乗った場合　吹き出し */
   display: block; /* block で表示 */
   /* top: 0px; */
   /* left: 0px; */
   z-index: 1;
   border: #000000 solid 1px; /* ボーダー(境界線) */
   background-color: #ffffe1; /* 背景色 */
   padding: 1px 2px 0px 3px; /* 内側の余白 */
   color: #000000; /* 文字色 */
}
.pop-up_balloon { /*吹き出し　デフォルト*/
   display: none; /* 非表示 */
   position: absolute;
}

-->
</style>

