         function OnLoad_Display( ){
            
            if(sJumpLocation != ""){
               
               if( (navigator.appName == sNetscapeNavigator) && (vVerCompatible < 5) ){
                  // Netscape
                  
                  location.hash = sJumpLocation;
                  
               }
               
            }
            
         }
         
         // -->
      </script>

