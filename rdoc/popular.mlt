      <script language="JavaScript">
         <!--
         
         function SubmitAdministraAction(oForm){
            var vPasswordLengthMax = 64;
            if(
             (document.FormAdministra==oForm) ||
             (document.FormAdministraEntry==oForm) ||
             (document.FormAdministraDelete==oForm)
            ){
               if(
                ("*&$AdministraButtonVisible&"!="hidden") && 
                (document.FormAdministraPassword.Password.value.length==0)
               ){
                  sProgramErrorMessage = sProgramErrorMessage+<&=(Administra):"★Passwordが入力されていません．"=&>+"\n";
               }
            }
            if( vPasswordLengthMax<vGetStringByte(document.FormAdministraPassword.Password.value) ){
               sProgramErrorMessage = sProgramErrorMessage+<&=(Administra):"★Passwordが その長さの上限の "+vPasswordLengthMax+" バイトを超えています．"=&>+"\n";
            }
            lProgramError = false; // true;
            if( ( *&$CodecVersion&+0 ) == 3 ){
               oForm.PasswordEncode.value = 
                EncodePassword_V3(document.FormAdministraPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
            }
            else if( ( *&$CodecVersion&+0 ) == 4 ){
               oForm.PasswordEncode.value = 
                EncodePassword_V4(document.FormAdministraPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
            }
            if( lProgramError ){
               document.FormAdministraPassword.Password.value = "";
               sProgramErrorMessage = sProgramErrorMessage+<&=(Administra):"★Passwordには｛半角のカナ，全角文字｝は使用できません．"=&>+"\n";
            }
            if( 0 < sProgramErrorMessage.length ){
               alert(sProgramErrorMessage);
               sProgramErrorMessage = "";
            }
            else{
               if(
                (document.FormAdministraPassword.Password.value.length!=0) ||
                (document.FormBoardSwitch==oForm)
               ){
                  oForm.submit( );
               }
            }
         }
         // -->
