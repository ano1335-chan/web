      <script language="JavaScript">
         <!--
         
         //Initialize.
         
         function InputPassword_OnLoad(){
            // alert("InputPassword_OnLoad()が実行された"+"\n");
         }
         
         function Submit_InputPassword(){
            lProgramError = false; // true;
            // "="++";\n"+
            // alert("Submit_InputPassword():\n"+"document.FormPassword.Password.value="+document.FormPassword.Password.value+";\n"+"");
            if( ( *&$CodecVersion&+0 ) == 3 ){
               document.FormInputPassword.PasswordEncode.value = 
                EncodePassword_V3(document.FormPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
            }
            else if( ( *&$CodecVersion&+0 ) == 4 ){
               document.FormInputPassword.PasswordEncode.value = 
                EncodePassword_V4(document.FormPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
            }
            if( lProgramError ){
               alert(<&=(InputPassword):"Passwordには｛半角のカナ，全角文字｝は使用できません"=&>+"\n");
               document.FormPassword.Password.value = "";
            }
            else{
               document.FormInputPassword.submit( );
            }
         }
         // -->
      </script>

