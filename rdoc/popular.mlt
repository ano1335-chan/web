<!-- Input Article（記事） Templet -->

      <script language="JavaScript">
         <!--
         
         //Initialize.
         
         dRadioButton[vRadioButton_FontPitch] = "*&$FontPitch&";
         dRadioButton[vRadioButton_FontPitchSetting] = "*&$FontPitchSetting&";
         // dRadioButton[vRadioButton_IconSelect] = "*&$IconSelect&";
         dRadioButton[vRadioButton_IconSelectSetting] = "*&$IconSelectSetting&";

         function Input_OnLoad(){
            
         }

         function SubmitContribution( ){
            if( 
             document.FormContribution.UserCheckCommentTitle.checked && 
             ( document.FormContribution.CommentTitle.value.length==0 ) 
            ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Title\"が入力されていません．"=&>+"\n";
            }
            if( *&$UserCommentTitleLengthMax&<vGetStringByte(document.FormContribution.CommentTitle.value) ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Title\"が その長さの上限の *&$UserCommentTitleLengthMax& バイトを超えています．"=&>+"\n";
            }
            if( 
             document.FormContribution.UserCheckHandleName.checked && 
             ( document.FormContribution.UserHandleName.value.length==0 ) 
            ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"HandleName\"が入力されていません．"=&>+"\n";
            }
            
            if( *&$UserHandleNameLengthMax&<vGetStringByte(document.FormContribution.UserHandleName.value) ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"HandleName\"が その長さの上限の *&$UserHandleNameLengthMax& バイトを超えています．"=&>+"\n";
            }
            if( document.FormContribution.Comment.value.length==0 ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Comment\"が入力されていません．"=&>+"\n";
            }
            
            if(
             (*&$AdministraMode&+0)==1 &&
             0<(*&$AdministraCommentCharLengthMax&+0)
            ){
               if( *&$AdministraCommentCharLengthMax&<document.FormContribution.Comment.value.length ){
                  sProgramErrorMessage = sProgramErrorMessage+<&="★\"Comment\"が その文字数の上限の *&$AdministraCommentCharLengthMax& 文字を超えています．"=&>+"\n";
               }
            }
            else{
               if( *&$UserCommentLengthMax&<vGetStringByte(document.FormContribution.Comment.value) ){
                  sProgramErrorMessage = sProgramErrorMessage+<&="★\"Comment\"が その長さの上限の *&$UserCommentLengthMax& バイトを超えています．"=&>+"\n";
               }
            }
            document.FormContribution.FontPitchSetting.value =
             dRadioButton[vRadioButton_FontPitchSetting];
            if( dRadioButton[vRadioButton_FontPitchSetting]=="" ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★「フォント･ピッチ･スイッチの設定」が入力されていません．"=&>+"\n";
            }
            else if( 
             (
              ( dRadioButton[vRadioButton_FontPitchSetting]=="Check" ) ||
              ( dRadioButton[vRadioButton_FontPitchSetting]=="Cookie" )
             ) &&
             ( dRadioButton[vRadioButton_FontPitch]=="" ) 
            ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★「フォント･ピッチ」が入力されていません．"=&>+"\n";
            }
//            alert(
//            "dRadioButton[vRadioButton_IconSelectSetting]="+dRadioButton[vRadioButton_IconSelectSetting]+";\n"+
//            "document.FormContribution.IconSelect.value="+document.FormContribution.IconSelect.value+";\n"+
//            "");
            if( typeof document.FormContribution.IconSelect!="undefined" ){
               document.FormContribution.IconSelectSetting.value =
                dRadioButton[vRadioButton_IconSelectSetting];
               if( dRadioButton[vRadioButton_IconSelectSetting]=="" ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★「Icon 選択の設定」が入力されていません．"=&>+"\n";
               }
               else if( 
                (
                 ( dRadioButton[vRadioButton_IconSelectSetting]=="Check" ) ||
                 ( dRadioButton[vRadioButton_IconSelectSetting]=="Cookie" )
                ) &&
                ( document.FormContribution.IconSelect.value<=" " ) 
               ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Icon\"が選択されていません．"=&>+"\n";
               }
            }
            if( 
             ( document.getElementById("PasswordComponent").style.display!="none" ) &&
             document.FormPassword.UserCheckPassword.checked && 
             ( document.FormPassword.Password.value=="" ) 
            ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Password\"が入力されていません．"=&>+"\n";
            }
            if( *&$UserPasswordLengthMax&<vGetStringByte(document.FormPassword.Password.value) ){
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Password\"が その長さの上限の *&$UserPasswordLengthMax& バイトを超えています．"=&>+"\n";
            }
            // document.FormContribution.PasswordEncode.value = "";
            lProgramError = false; // true;
            if(
             ( document.getElementById("PasswordComponent").style.display!="none" ) &&
             ( document.FormPassword.Password.value!="" )
            ){
               if( ( *&$CodecVersion&+0 ) == 3 ){
                  document.FormContribution.PasswordEncode.value = 
                   EncodePassword_V3(document.FormPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
               }
               else if( ( *&$CodecVersion&+0 ) == 4 ){
                  document.FormContribution.PasswordEncode.value = 
                   EncodePassword_V4(document.FormPassword.Password.value,*&$Cipher_DiffiHellman_Factor&);
               }
            }
            // alert(document.FormContribution.PasswordEncode.value);
            if( lProgramError ){
               document.FormPassword.Password.value = "";
               sProgramErrorMessage = sProgramErrorMessage+<&="★\"Password\"には｛半角のカナ，全角文字｝は使用できません．"=&>+"\n";
            }
            
            if( document.FormPassword.UserCheckPassword.checked ){
               document.FormContribution.UserCheckPassword.value = 
                document.FormPassword.UserCheckPassword.value;
            }
            if( document.FormPassword.UserMaintHandleName.checked ){
               document.FormContribution.UserMaintHandleName.value = 
                document.FormPassword.UserMaintHandleName.value;
            }
            if( 0 < sProgramErrorMessage.length ){
               alert(sProgramErrorMessage);
               sProgramErrorMessage = "";
            }
            else{
               if(sSubmitMessage!=""){
                  alert(sSubmitMessage);
               }
               else{
                  sSubmitMessage = <&="記事･投稿の｛コマンド；データ｝の送信中ですので しばらく お待ち下さい．"=&>;
                  document.FormContribution.submit( );
               }
            }
         }

         function ResetContribution(oForm){
            if(sSubmitMessage!=""){
               alert(sSubmitMessage);
            }
            else{
               oForm.UserCheckCommentTitle.value = "off";
               if(document.FormContribution.UserCheckCommentTitle.checked){
                  oForm.UserCheckCommentTitle.value = document.FormContribution.UserCheckCommentTitle.value;
               }
               oForm.UserCheckHandleName.value = "off";
               if(document.FormContribution.UserCheckHandleName.checked){
                  oForm.UserCheckHandleName.value = document.FormContribution.UserCheckHandleName.value;
               }
               oForm.UserMaintHandleName.value = "off";
               if(document.FormContribution.UserMaintHandleName.checked){
                  oForm.UserMaintHandleName.value = document.FormContribution.UserMaintHandleName.value;
               }
               oForm.UserCheckPassword.value = "off";
               if(document.FormContribution.UserCheckPassword.checked){
                  oForm.UserCheckPassword.value = document.FormContribution.UserCheckPassword.value;
               }
               oForm.FontPitch.value = dRadioButton[vRadioButton_FontPitch];
               oForm.FontPitchSetting.value = dRadioButton[vRadioButton_FontPitchSetting];
               oForm.IconSelect.value = document.FormContribution.IconSelect.value;
               oForm.IconSelectSetting.value = dRadioButton[vRadioButton_IconSelectSetting];
               // alert("oForm.IconSelectSetting.value="+oForm.IconSelectSetting.value);
               oForm.submit( );
            }
         }
         // -->
      </script>

